---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Huishoudelijk reglement | VC HEBO Jeugd">
  <section class="hero">
    <div class="hero__container">
      <h1 class="hero__title">Huishoudelijk reglement</h1>
      <p class="hero__subtitle">Officiële versie van het reglement (PDF)</p>
      <a class="hero__download" href="/docs/huishoudelijk-reglement.pdf" target="_blank" rel="noopener noreferrer">
        Open / download PDF
      </a>
    </div>
  </section>

  <section class="doc">
    <div class="doc__container">
      <iframe
        src="/docs/huishoudelijk-reglement.pdf"
        title="Huishoudelijk reglement VC HEBO Jeugd"
        class="doc__frame"
      ></iframe>
    </div>
  </section>
</BaseLayout>

<style>
  main {
    background: #fafafa;
  }

  .hero {
    background: #1e3264;
    color: #fff;
    padding: 8rem 2rem 3rem;
    text-align: center;
  }

  .hero__container {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero__title {
    margin: 0;
    font-size: clamp(2.4rem, 5.8vw, 4rem);
    font-weight: 900;
  }

  .hero__subtitle {
    margin: 0.8rem 0 1.5rem;
    opacity: 0.85;
  }

  .hero__download {
    display: inline-block;
    background: #fff;
    color: #1e3264;
    padding: 0.8rem 1.3rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
  }

  .doc {
    padding: 2rem;
    background: #fff;
  }

  .doc__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .doc__frame {
    width: 100%;
    height: 80vh;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
  }

  @media (max-width: 700px) {
    .hero { padding: 6rem 1rem 2.5rem; }
    .doc { padding: 1rem; }
    .doc__frame { height: 72vh; }
  }
</style>
