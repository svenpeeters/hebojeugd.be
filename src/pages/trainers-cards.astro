---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrainerTradingCard from '../components/TrainerTradingCard.astro';

const trainerGroups = [
  {
    title: 'Onderbouw',
    ageRange: 'U5 - U9',
    color: 'green',
    trainers: [
      { team: 'U5', name: 'Amber Freson' },
      { team: 'U5', name: 'Nicky Berwaerts' },
      { team: 'U6', name: 'Kenji Jossa' },
      { team: 'U7', name: 'Timothy Fontaine' },
      { team: 'U9', name: 'Dave Daniels' },
      { team: 'U9', name: 'Kevin Castro' },
    ],
  },
  {
    title: 'Middenbouw',
    ageRange: 'U10 - U13',
    color: 'orange',
    trainers: [
      { team: 'U10', name: 'Willy Missotten' },
      { team: 'U10', name: 'Jurgen Polders' },
      { team: 'U11/12', name: 'Andy Bex' },
      { team: 'U11/12', name: 'Frank Missotten' },
    ],
  },
  {
    title: 'Bovenbouw',
    ageRange: 'U14 - U17',
    color: 'red',
    trainers: [
      { team: 'U15', name: 'Jean-Marie Cloesen' },
      { team: 'U15', name: 'Roger Vanhaeren' },
      { team: 'U17', name: 'Joeri Fontaine' },
    ],
  },
  {
    title: 'Keeperstrainer',
    ageRange: 'Alle teams',
    color: 'navy',
    trainers: [{ team: 'Alle teams', name: 'Gilles Vanswijgenhoven' }],
  },
];

const padToLength = (text: string, target = 112) => {
  if (text.length === target) return text;
  if (text.length > target) return `${text.slice(0, target - 1)}…`;
  return text.padEnd(target, ' ');
};

const buildDescription = (trainer: { team: string; name: string }) => {
  const firstName = trainer.name.split(' ')[0];
  const variants = [
    `Trainer van ${trainer.team}. ${firstName} leest het spel slim, scherpt passing aan en zet iedereen perfect in positie.`,
    `Trainer van ${trainer.team}. ${firstName} brengt tempo, strakke passing en slim positiespel met duidelijke coaching.`,
    `Trainer van ${trainer.team}. ${firstName} bouwt rust in het spel, laat passing tikken en houdt de linies compact.`,
    `Trainer van ${trainer.team}. ${firstName} stuurt met flair, slijpt passing bij en zet het positiespel messcherp neer.`,
  ];

  const index = trainer.name.length % variants.length;
  return padToLength(variants[index]);
};

const buildCardData = (trainer: { team: string; name: string }) => ({
  card_type: 'Trainer',
  trainer_name: trainer.name,
  corner_symbol: trainer.team,
  image:
    trainer.name === 'Gilles Vanswijgenhoven'
      ? '/images/trainers/keeperstrainer-example.png'
      : trainer.name === 'Willy Missotten'
        ? '/images/trainers/willy-missotten.png'
        : trainer.name === 'Jurgen Polders'
          ? '/images/trainers/jurgen-polders.png'
          : trainer.name === 'Andy Bex'
            ? '/images/trainers/andy-bex.png'
            : trainer.name === 'Frank Missotten'
              ? '/images/trainers/frank-missotten.png'
              : trainer.name === 'Kenji Jossa'
                ? '/images/trainers/kenji-jossa.png'
                : '/images/trainers/timothy-fontaine.png',
  actions: [
    {
      types: ['Grass', 'Leaf'],
      name: 'Team Coaching',
      damage: '20',
      description: buildDescription(trainer),
    },
  ],
  flavor_text: `${trainer.name} begeleidt ${trainer.team} met rust, structuur en enthousiasme.`,
  copyright: '©2026 VC HEBO Jeugd',
  collector_info: `${trainer.team} • HEBO`,
});
---

<BaseLayout title="Trainers cards | VC HEBO Jeugd" noindex={true}>
  <section class="hero">
    <div class="hero__container">
      <h1 class="hero__title">Trainersstaf</h1>
      <p class="hero__subtitle">Alle trainers als cards, netjes naast elkaar.</p>
    </div>
  </section>

  <section class="trainers-cards">
    <div class="trainers-cards__container">
      {trainerGroups.map((group) => (
        <section class="cards-group">
          <div class="cards-group__header">
            <h2 class="cards-group__title">{group.title}</h2>
            <span class="cards-group__range">{group.ageRange}</span>
          </div>

          <div class="cards-grid">
            {group.trainers.map((trainer) => (
              <TrainerTradingCard data={buildCardData(trainer)} accent={group.color as any} compact />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  main { background: #fafafa; }

  .hero {
    background: #1e3264;
    color: #fff;
    padding: 8rem 2rem 4rem;
    text-align: center;
  }

  .hero__container { max-width: 900px; margin: 0 auto; }
  .hero__title { font-size: clamp(2.5rem, 6vw, 4rem); margin: 0; font-weight: 900; }
  .hero__subtitle { margin: .9rem 0 0; opacity: .85; }

  .trainers-cards {
    padding: 4rem 2rem;
    background: #fff;
  }

  .trainers-cards__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .cards-group {
    margin-bottom: 3rem;
  }

  .cards-group__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .cards-group__title {
    margin: 0;
    color: #1e3264;
    font-size: 1.6rem;
    font-weight: 900;
  }

  .cards-group__range {
    font-size: 0.8rem;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: #64748b;
    font-weight: 700;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  @media (max-width: 700px) {
    .cards-group__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
