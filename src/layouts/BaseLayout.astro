---
import NavbarAlt from '../components/NavbarAlt.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  transparentNav?: boolean;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "VC HEBO Jeugd - Jeugdvoetbal in Heers-Bovelingen",
  transparentNav = false,
  ogImage = '/logo.png',
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://www.hebojeugd.be');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsClub',
  name: 'VC HEBO Jeugd',
  url: siteUrl.toString(),
  logo: new URL('/logo.png', siteUrl).toString(),
  sport: 'Football',
  email: 'info@hebojeugd.be',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Heers',
    postalCode: '3870',
    addressCountry: 'BE',
  },
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VC HEBO Jeugd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)}></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JYL4TFX370"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'G-JYL4TFX370');
    </script>
  </head>
  <body>
    <NavbarAlt transparent={transparentNav} />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      const trackEvent = (eventName, params = {}) => {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, params);
        }
      };

      const slugify = (value = '') => value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '')
        .slice(0, 40);

      const pageKey = window.location.pathname.replace(/^\//, '').replace(/\//g, '_') || 'home';

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('a, button') : null;
        if (!target) return;

        const href = target.getAttribute('href') || '';
        const text = (target.textContent || '').trim().replace(/\s+/g, ' ').slice(0, 120);
        const page_path = window.location.pathname;
        const linkKey = slugify(text) || slugify(href) || 'unknown';

        if (href.startsWith('mailto:')) {
          trackEvent('mailto_click', {
            email_address: href.replace('mailto:', ''),
            link_text: text,
            page_path,
          });
          trackEvent(`${pageKey}_mailto_click`, {
            email_address: href.replace('mailto:', ''),
            link_text: text,
            page_path,
          });
          return;
        }

        if (href.startsWith('http') && !href.includes(window.location.hostname)) {
          trackEvent('outbound_click', {
            destination: href,
            link_text: text,
            page_path,
          });
          trackEvent(`${pageKey}_outbound_click`, {
            destination: href,
            link_text: text,
            page_path,
          });
          return;
        }

        const cta = target.closest('.cta__button, .hero__button, .nav-fullscreen__link, .footer__link');
        if (cta) {
          trackEvent('cta_click', {
            destination: href || text,
            link_text: text,
            page_path,
          });
          trackEvent(`${pageKey}_cta_click`, {
            destination: href || text,
            link_text: text,
            link_key: linkKey,
            page_path,
          });
        }
      }, { passive: true });

      let scrollTracked = {25:false, 50:false, 75:false, 90:false};
      document.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight <= 0) return;
        const pct = Math.round((scrollTop / docHeight) * 100);
        [25, 50, 75, 90].forEach((mark) => {
          if (!scrollTracked[mark] && pct >= mark) {
            scrollTracked[mark] = true;
            trackEvent('scroll_depth', { percent_scrolled: mark, page_path: window.location.pathname });
            trackEvent(`${pageKey}_scroll_depth`, { percent_scrolled: mark, page_path: window.location.pathname });
          }
        });
      }, { passive: true });
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  :root {
    --navy: #1e3264;
    --white: #ffffff;
    --red: #c8202f;
    --gray: #757575;
    --light: #f5f5f5;
  }
  body {
    font-family: 'Inter', sans-serif;
    background: var(--white);
    color: var(--navy);
    overflow-x: hidden;
  }
  main {
    /* min-height removed per feedback */
  }
</style>
