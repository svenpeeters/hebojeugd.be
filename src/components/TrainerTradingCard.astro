---
interface ActionItem {
  types: string[];
  name: string;
  damage: string;
  description: string;
}

interface TrainerCardData {
  card_type: string;
  trainer_name: string;
  corner_symbol: string;
  image: string;
  actions: ActionItem[];
  flavor_text: string;
  copyright: string;
  collector_info: string;
}

interface Props {
  data: TrainerCardData;
  compact?: boolean;
  accent?: 'green' | 'orange' | 'red' | 'navy';
}

const { data, compact = false, accent = 'green' } = Astro.props;

const accentClass = `trainer-card--${accent}`;

const iconLabel = (type: string) => {
  switch (type.toLowerCase()) {
    case 'grass':
      return '🌿';
    case 'leaf':
      return '🍃';
    case 'star':
      return '★';
    default:
      return '•';
  }
};
---

<article class:list={["trainer-card-wrap", compact && "trainer-card-wrap--compact"]}>
  <div class:list={["trainer-card", accentClass, compact && "trainer-card--compact"]} role="img" aria-label={`${data.card_type} kaart van ${data.trainer_name}`}>
    <div class="trainer-card__foil"></div>

    <header class="trainer-card__header">
      <h2 class="trainer-card__name">{data.trainer_name}</h2>
      <span class="trainer-card__corner">{data.corner_symbol}</span>
    </header>

    <div class="trainer-card__image-frame">
      <img src={data.image} alt={data.trainer_name} loading="lazy" />
    </div>

    <section class="trainer-card__actions">
      {data.actions.map((action) => (
        <div class="trainer-card__action">
          <p>{action.description}</p>
        </div>
      ))}
    </section>

    <footer class="trainer-card__footer">
      <small>{data.copyright}</small>
      <small>{data.collector_info}</small>
    </footer>
  </div>
</article>

<style>
  .trainer-card-wrap {
    display: grid;
    place-items: center;
    padding: 3rem 1rem;
    perspective: 1200px;
  }

  .trainer-card-wrap--compact {
    padding: 0;
  }

  .trainer-card {
    width: min(100%, 440px);
    border-radius: 24px;
    padding: 14px;
    background:
      linear-gradient(130deg, #f7f9fb 0%, #cfd6dd 16%, #f8fafc 34%, #b8c0c9 52%, #f8fafc 70%, #c5cdd6 100%);
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 0 -2px 8px rgba(0, 0, 0, 0.14);
    position: relative;
    overflow: hidden;
  }

  .trainer-card--compact {
    width: 100%;
    max-width: 340px;
  }

  .trainer-card--green { --card-accent-1: #4ade80; --card-accent-2: #22c55e; }
  .trainer-card--orange { --card-accent-1: #f59e0b; --card-accent-2: #d97706; }
  .trainer-card--red { --card-accent-1: #ef4444; --card-accent-2: #c8202f; }
  .trainer-card--navy { --card-accent-1: #1e3264; --card-accent-2: #142347; }

  .trainer-card::before {
    content: '';
    position: absolute;
    inset: 12px;
    border-radius: 16px;
    pointer-events: none;
    opacity: 0.45;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.34) 0,
        rgba(255, 255, 255, 0.34) 1px,
        rgba(0, 0, 0, 0.0) 1px,
        rgba(0, 0, 0, 0.0) 2px
      ),
      repeating-linear-gradient(
        115deg,
        rgba(255, 255, 255, 0.12) 0,
        rgba(255, 255, 255, 0.12) 2px,
        rgba(0, 0, 0, 0.06) 2px,
        rgba(0, 0, 0, 0.06) 4px
      );
    mix-blend-mode: soft-light;
    transition: opacity 0.2s ease;
  }

  .trainer-card__image-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(255,255,255,0.42) 0,
      rgba(255,255,255,0.42) 1px,
      rgba(0,0,0,0.02) 1px,
      rgba(0,0,0,0.02) 2px
    );
    mix-blend-mode: overlay;
    transition: opacity 0.2s ease;
  }

  .trainer-card__foil {
    position: absolute;
    inset: -30% -50%;
    background: radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.35), transparent 40%);
    pointer-events: none;
    transform: rotate(-9deg);
  }

  .trainer-card::after {
    content: '';
    position: absolute;
    inset: 10px;
    border-radius: 16px;
    pointer-events: none;
    opacity: 0;
    background:
      linear-gradient(120deg,
        rgba(255, 0, 128, 0.0) 0%,
        rgba(255, 0, 128, 0.32) 18%,
        rgba(0, 200, 255, 0.34) 36%,
        rgba(120, 255, 120, 0.34) 54%,
        rgba(255, 220, 80, 0.30) 72%,
        rgba(164, 93, 255, 0.28) 86%,
        rgba(255, 0, 128, 0.0) 100%);
    background-size: 250% 250%;
    mix-blend-mode: screen;
    transition: opacity 0.18s ease;
  }

  .trainer-card:hover::after {
    opacity: 1;
    animation: holoShift 1s linear infinite;
  }

  .trainer-card:hover::before {
    opacity: 1;
    animation: scanlineShift 0.28s linear infinite;
  }

  .trainer-card:hover .trainer-card__image-frame::after {
    opacity: 1;
    animation: scanlineShift 0.2s linear infinite;
  }

  .trainer-card {
    --rx: 0deg;
    --ry: 0deg;
    transform-style: preserve-3d;
    transition: transform 0.12s ease;
  }

  .trainer-card:hover {
    transform: translateY(-4px) rotateX(var(--rx)) rotateY(var(--ry)) rotateZ(-0.25deg);
  }

  @keyframes holoShift {
    0% { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  @keyframes scanlineShift {
    0% { transform: translateY(0); }
    100% { transform: translateY(2px); }
  }

  .trainer-card__header,
  .trainer-card__image-frame,
  .trainer-card__actions,
  .trainer-card__flavor,
  .trainer-card__footer {
    position: relative;
    z-index: 2;
  }

  .trainer-card__header {
    background: linear-gradient(180deg, var(--card-accent-1), var(--card-accent-2));
    border-radius: 12px;
    color: #fff;
    padding: 0.85rem 1rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
  }

  .trainer-card__name {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.2;
    font-weight: 900;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .trainer-card__corner {
    font-weight: 800;
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.18);
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
  }

  .trainer-card__image-frame {
    margin-top: 0.75rem;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    border: 2px solid rgba(255, 255, 255, 0.7);
    background: #f2f5f7;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.1);
  }

  .trainer-card__image-frame img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .trainer-card__actions {
    margin-top: 0.75rem;
    display: grid;
    gap: 0.7rem;
  }

  .trainer-card__action {
    background: rgba(255, 255, 255, 0.72);
    border-radius: 10px;
    padding: 0.7rem 0.8rem;
  }

  .trainer-card__action-top {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.55rem;
  }

  .trainer-card__icons {
    display: inline-flex;
    gap: 0.3rem;
  }

  .icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: inline-grid;
    place-items: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    box-shadow: inset 0 -1px 2px rgba(0,0,0,.25);
  }

  .icon--grass { background: #2ba84a; }
  .icon--leaf { background: #56bf72; }
  .icon--star { background: #0f172a; }

  .trainer-card__action h3 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 800;
    color: #132b22;
  }

  .trainer-card__action strong {
    font-size: 1rem;
    color: #111827;
  }

  .trainer-card__action p {
    margin: 0.4rem 0 0;
    font-size: 0.78rem;
    line-height: 1.45;
    color: #243640;
  }

  .trainer-card__flavor {
    margin-top: 0.7rem;
    background: linear-gradient(180deg, #4fa75f, #2f7f43);
    color: #ecfdf3;
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    font-size: 0.74rem;
    line-height: 1.35;
    text-align: center;
  }

  .trainer-card__footer {
    margin-top: 0.7rem;
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    font-size: 0.62rem;
    color: #1f2937;
    opacity: 0.9;
  }
</style>

<script is:inline>
  document.querySelectorAll('.trainer-card').forEach((card) => {
    const maxTilt = 12;

    const onMove = (event) => {
      const rect = card.getBoundingClientRect();
      const px = (event.clientX - rect.left) / rect.width;
      const py = (event.clientY - rect.top) / rect.height;

      const ry = (px - 0.5) * (maxTilt * 2);
      const rx = (0.5 - py) * (maxTilt * 2);

      card.style.setProperty('--rx', `${rx.toFixed(2)}deg`);
      card.style.setProperty('--ry', `${ry.toFixed(2)}deg`);
    };

    const reset = () => {
      card.style.setProperty('--rx', '0deg');
      card.style.setProperty('--ry', '0deg');
    };

    card.addEventListener('pointermove', onMove);
    card.addEventListener('pointerleave', reset);
  });
</script>
